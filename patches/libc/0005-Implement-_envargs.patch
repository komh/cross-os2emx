 libcrossemx_SRCS := crossemx.c
diff --git a/src/emx/src/libcrossemx/crossemx.c b/src/emx/src/libcrossemx/crossemx.c
index faf05a0..f691fcc 100644
--- a/src/emx/src/libcrossemx/crossemx.c
+++ b/src/emx/src/libcrossemx/crossemx.c
@@ -30,6 +30,7 @@ Boston, MA 02111-1307, USA.  */
 #include <sys/param.h>
 #include <sys/wait.h>
 #include <errno.h>
+#include <libiberty.h>
 
 #include "crossemx.h"
 
@@ -311,6 +312,45 @@ int _fullpath (char *dst, const char *src, int size)
   return 0;
 }
 
+void _envargs (int *argcp, char ***argvp, const char *name)
+{
+  int argc = *argcp;
+  char **argv = *argvp;
+  int envargc;
+  char **envargv;
+  const char *envopt = getenv (name);
+  int newargc;
+  char **newargv;
+  int i;
+
+  if (envopt == NULL || *envopt == 0)
+    return;
+
+  envargv = buildargv (envopt);
+  if (envargv == NULL)
+    return;
+
+  envargc = countargv (envargv);
+
+  newargc = argc + envargc;
+  newargv = xmalloc (sizeof (char *) * (newargc + 1));
+
+  newargv[0] = argv[0];
+
+  /* Copy args from env first */
+  for (i = 0; i < envargc; i++)
+    newargv[1 + i] = envargv[i];
+
+  /* Copy args from argv now */
+  for (i = 1; i < argc; i++)
+    newargv[envargc + i] = argv[i];
+
+  /* FIXME: envargv leaks */
+
+  *argcp = newargc;
+  *argvp = newargv;
+}
+
 /* process.h */
 
 /* for spawnvp (P_WAIT) */
diff --git a/src/emx/src/libcrossemx/crossemx.h b/src/emx/src/libcrossemx/crossemx.h
index 62c3987..0581523 100644
--- a/src/emx/src/libcrossemx/crossemx.h
+++ b/src/emx/src/libcrossemx/crossemx.h
@@ -44,6 +44,7 @@ void _splitpath (const char *src, char *drive, char *dir, char *fname,
 int _execname (char *buf, size_t bufsize);
 char *_realrealpath(const char *path, char *resolved, size_t size);
 int _fullpath (char *dst, const char *src, int size);
+void _envargs (int *argcp, char ***argvp, const char *name);
 
 /* fcntl.h */
 #define O_BINARY 0
