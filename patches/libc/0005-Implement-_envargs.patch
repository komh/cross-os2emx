 src/emx/src/libcrossemx/Makefile.cross |  2 ++
 src/emx/src/libcrossemx/crossemx.c     | 40 ++++++++++++++++++++++++++
 src/emx/src/libcrossemx/crossemx.h     |  1 +
 6 files changed, 48 insertions(+), 1 deletion(-)

