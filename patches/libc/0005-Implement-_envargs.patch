diff --git a/src/emx/src/emxomf/emxomf.c b/src/emx/src/emxomf/emxomf.c
index 4b4268e..7e0893b 100644
--- a/src/emx/src/emxomf/emxomf.c
+++ b/src/emx/src/emxomf/emxomf.c
@@ -4166,12 +4166,14 @@ int main (int argc, char *argv[])
      GCCLOAD environment variable. */
 
   _emxload_env ("GCCLOAD");
+#endif
 
   /* Get options from the EMXOMFOPT environment variable, expand
      response files (@filename) and wildcard (*.o) on the command
      line. */
 
   _envargs (&argc, &argv, "EMXOMFOPT");
+#ifdef __EMX__
   _response (&argc, &argv);
   _wildcard (&argc, &argv);
 #else
diff --git a/src/emx/src/emxomf/emxomfstrip.c b/src/emx/src/emxomf/emxomfstrip.c
index 0ce8a38..4f16385 100644
--- a/src/emx/src/emxomf/emxomfstrip.c
+++ b/src/emx/src/emxomf/emxomfstrip.c
@@ -295,8 +295,8 @@ int main(int argc, char **argv)
 #endif
 
     /* Get more arguments from EMXOMFSTRIPOPT and load reponse files and expand wildcards. */
-#ifdef __EMX__
     _envargs(&argc, &argv, "EMXOMFSTRIPOPT");
+#ifdef __EMX__
     _response(&argc, &argv);
     _wildcard(&argc, &argv);
 #else
diff --git a/src/emx/src/libcrossemx/Makefile.cross b/src/emx/src/libcrossemx/Makefile.cross
index d918aa2..11eea76 100644
--- a/src/emx/src/libcrossemx/Makefile.cross
+++ b/src/emx/src/libcrossemx/Makefile.cross
@@ -26,6 +26,8 @@
 EMXDIR := ../..
 SRCDIR := .
 
+BINUTILSDIR := ../../../../../binutils-os2
+
