index fc7fce4..b57037a 100644
--- a/src/emx/src/emxbind/Makefile.cross
+++ b/src/emx/src/emxbind/Makefile.cross
@@ -26,6 +26,8 @@
 EMXDIR := ../..
 SRCDIR := .
 
