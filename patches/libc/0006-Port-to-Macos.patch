 src/emx/src/emxbind/resource.c     |  2 +-
 src/emx/src/emxbind/utils.c        |  2 +-
 src/emx/src/emximp/emximp.c        |  2 +-
 src/emx/src/emxomf/emxomfar.c      |  2 +-
 src/emx/src/emxomf/emxomfld.c      |  2 +-
 src/emx/src/emxomf/weakld.c        | 13 ++++++++++---
 src/emx/src/libcrossemx/crossemx.c | 18 ++++++++++++++++++
 8 files changed, 34 insertions(+), 9 deletions(-)

diff --git a/src/emx/common.cross b/src/emx/common.cross
index 62d81fb..e0785f9 100644
--- a/src/emx/common.cross
+++ b/src/emx/common.cross
@@ -114,7 +114,7 @@ $$($(1)_OBJS) $$($(1)_DEPS): CFLAGS += $($(1)_CFLAGS)
 $(1)_TARGET := $(OUTDIR)/$(1)$(LIBEXT)
 
 $$($(1)_TARGET): $$($(1)_OBJS)
-	$(AR) $(ARFLAGS) $$($(1)_ARFLAGS) -o $$@ $$($(1)_OBJS)
+	$(AR) $(ARFLAGS) $$($(1)_ARFLAGS) $$@ $$($(1)_OBJS)
 
 all: $$($(1)_TARGET)
 
