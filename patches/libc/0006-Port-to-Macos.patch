+++ b/src/emx/src/libcrossemx/crossemx.c
@@ -31,6 +31,10 @@ Boston, MA 02111-1307, USA.  */
 #include <sys/wait.h>
 #include <errno.h>
 #include <libiberty.h>
+#if defined __APPLE__
+#include <mach-o/dyld.h>
+#include <libgen.h>
+#endif
 
 #include "crossemx.h"
 
@@ -261,6 +265,7 @@ void _splitpath (const char *src, char *drive, char *dir, char *fname,
     _strncpy (ext, src, _MAX_EXT);
 }
 
+#if !defined __APPLE__
 int _execname (char *buf, size_t bufsize)
 {
   ssize_t len;
@@ -271,6 +276,19 @@ int _execname (char *buf, size_t bufsize)
   buf[len] = '\0';
   return 0;
 }
+#else
+int _execname (char *buf, size_t bufsize)
+{
+  char path[1024];
+  uint32_t size = sizeof(path);
+
+  if (_NSGetExecutablePath(path, &size) == -1)
+    return -1;
+  _realrealpath(path, buf, bufsize);
+
+  return 0;
+}
+#endif
 
 char *_realrealpath (const char *path, char *resolved, size_t size)
 {
