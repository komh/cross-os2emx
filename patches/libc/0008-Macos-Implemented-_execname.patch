From: "github-actions[bot]"
 <41898282+github-actions[bot]@users.noreply.github.com>
Date: Sat, 11 Apr 2026 00:00:38 +0200
Subject: [PATCH] Macos: Implemented _execname

---
 src/emx/src/libcrossemx/crossemx.c | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/src/emx/src/libcrossemx/crossemx.c b/src/emx/src/libcrossemx/crossemx.c
index f691fcc..e00c21a 100644
--- a/src/emx/src/libcrossemx/crossemx.c
+++ b/src/emx/src/libcrossemx/crossemx.c
@@ -261,6 +261,7 @@ void _splitpath (const char *src, char *drive, char *dir, char *fname,
     _strncpy (ext, src, _MAX_EXT);
 }
 
+#if !defined __APPLE__
 int _execname (char *buf, size_t bufsize)
 {
   ssize_t len;
@@ -271,6 +272,22 @@ int _execname (char *buf, size_t bufsize)
   buf[len] = '\0';
   return 0;
 }
+#else
+#include <mach-o/dyld.h>
+#include <libgen.h>
+
+int _execname (char *buf, size_t bufsize)
+{
+  char path[1024];
+  uint32_t size = sizeof(path);
+
+  if (_NSGetExecutablePath(path, &size) == -1)
+    return -1;
+  _realrealpath(path, buf, bufsize);
+
+  return 0;
+}
+#endif
 
 char *_realrealpath (const char *path, char *resolved, size_t size)
 {
