From 53212cb4249391cbc6b5308c3ecce654b730bf6b Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Jochen=20Sch=C3=A4fer?= <josch1710@live.de>
Date: Wed, 8 Apr 2026 09:02:57 +0200
Subject: [PATCH 9/9] Port to Macos

1. conf-cross-os2emx: Remove TARGET_OS_MAC from compilation

2. gcc/configure.ac: Remove newline from GLIBC_VERSION
---
 conf-cross-os2emx | 6 ++++++
 gcc/configure.ac  | 4 ++--
 2 files changed, 8 insertions(+), 2 deletions(-)

diff --git a/conf-cross-os2emx b/conf-cross-os2emx
index a0f85e140a..869a44a170 100755
--- a/conf-cross-os2emx
+++ b/conf-cross-os2emx
@@ -29,4 +29,10 @@ opts="
     --disable-symvers
 "
 
+uname_s="$(uname -s)"
+if [ "x$uname_s" = "xDarwin" ]; then
+  CFLAGS="$CFLAGS -UTARGET_OS_MAC"
+  CXXFLAGS="$CXXFLAGS -UTARGET_OS_MAC"
+fi
+
 $(dirname $0)/configure $opts "$@"
diff --git a/gcc/configure.ac b/gcc/configure.ac
index ffa76a323c..1a413fc98b 100644
--- a/gcc/configure.ac
+++ b/gcc/configure.ac
@@ -6043,8 +6043,8 @@ glibc_version_minor=0
 [if test -f $target_header_dir/features.h \
   && glibc_version_major_define=`$EGREP '^[ 	]*#[ 	]*define[ 	]+__GLIBC__[ 	]+[0-9]' $target_header_dir/features.h` \
   && glibc_version_minor_define=`$EGREP '^[ 	]*#[ 	]*define[ 	]+__GLIBC_MINOR__[ 	]+[0-9]' $target_header_dir/features.h`; then
-  glibc_version_major=`echo "$glibc_version_major_define" | sed -e 's/.*__GLIBC__[ 	]*//'`
-  glibc_version_minor=`echo "$glibc_version_minor_define" | sed -e 's/.*__GLIBC_MINOR__[ 	]*//'`
+  glibc_version_major=`echo "$glibc_version_major_define" | sed -e 's/.*__GLIBC__[ 	]*//'  -e 's/[ 	]*[^0-9].*//'`
+  glibc_version_minor=`echo "$glibc_version_minor_define" | sed -e 's/.*__GLIBC_MINOR__[ 	]*//'  -e 's/[ 	]*[^0-9].*//'`
 fi]])
 AC_MSG_RESULT([$glibc_version_major.$glibc_version_minor])
 AC_DEFINE_UNQUOTED([TARGET_GLIBC_MAJOR], [$glibc_version_major],
-- 
2.43.0

