From 5ed84d4538ff7b5964f6c35d2e96763fecffe0c8 Mon Sep 17 00:00:00 2001
From: KO Myung-Hun <komh78@gmail.com>
Date: Sun, 1 Mar 2026 18:34:46 +0900
Subject: [PATCH 5/9] Build libssp

---
 conf-cross-os2emx | 1 -
 mk-cross-os2emx   | 2 ++
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/conf-cross-os2emx b/conf-cross-os2emx
index 04d18c5c08..a0f85e140a 100755
--- a/conf-cross-os2emx
+++ b/conf-cross-os2emx
@@ -22,7 +22,6 @@ opts="
     --enable-checking=release
     --disable-bootstrap
     --disable-nls
-    --disable-ssp
     --disable-libquadmath
     --disable-libgomp
     --disable-multilib
diff --git a/mk-cross-os2emx b/mk-cross-os2emx
index 843266240c..d20560e3eb 100755
--- a/mk-cross-os2emx
+++ b/mk-cross-os2emx
@@ -3,9 +3,11 @@
 make all-gcc \
      all-target-libgcc \
      all-target-libstdc++-v3 \
+     all-target-libssp \
      "$@" || exit 1
 
 make install-gcc \
      install-target-libgcc \
      install-target-libstdc++-v3 \
+     install-target-libssp \
      "$@"
-- 
2.43.0

