From 46a8d6efb43d402c33751f14cdc484ee4e736972 Mon Sep 17 00:00:00 2001
From: KO Myung-Hun <komh78@gmail.com>
Date: Thu, 19 Mar 2026 23:17:02 +0900
Subject: [PATCH 2/8] Allow to cross-compile for *-os2-emx target

---
 gcc/Makefile.in                 |  2 +-
 gcc/config/i386/emx-driver.c    |  4 +++-
 gcc/config/i386/emx.c           |  4 ++--
 gcc/config/i386/emx.h           | 10 ++++++++--
 gcc/config/i386/i386-options.cc |  4 ++--
 gcc/config/i386/i386.cc         | 10 +++++-----
 gcc/config/i386/i386.h          |  2 +-
 gcc/config/i386/predicates.md   |  2 +-
 gcc/config/i386/t-emx           |  2 +-
 gcc/cp/dump.cc                  |  8 ++++----
 gcc/gcc.cc                      |  6 +++---
 gcc/genattrtab.cc               |  2 +-
 gcc/gengtype.cc                 |  4 ++--
 gcc/reg-stack.cc                |  4 ++--
 gcc/reload1.cc                  |  2 +-
 gcc/target-def.h                |  4 ++--
 libstdc++-v3/crossconfig.m4     |  6 ++++++
 17 files changed, 45 insertions(+), 31 deletions(-)

diff --git a/gcc/Makefile.in b/gcc/Makefile.in
index 06a3924b51..3b81e4df66 100644
--- a/gcc/Makefile.in
+++ b/gcc/Makefile.in
@@ -465,7 +465,7 @@ LIBDECNUMBER = ../libdecnumber/libdecnumber.a
 # The backtrace library.
 BACKTRACE = $(srcdir)/../libbacktrace
 BACKTRACEINC = -I$(BACKTRACE)
-LIBBACKTRACE = ../libbacktrace/.libs/backtrace.a
+LIBBACKTRACE = ../libbacktrace/.libs/libbacktrace.a
 
 # Target to use when installing include directory.  Either
 # install-headers-tar, install-headers-cpio or install-headers-cp.
diff --git a/gcc/config/i386/emx-driver.c b/gcc/config/i386/emx-driver.c
index 5a1069104d..fe84e1c854 100644
--- a/gcc/config/i386/emx-driver.c
+++ b/gcc/config/i386/emx-driver.c
@@ -33,14 +33,16 @@ void
 emx_driver_init (unsigned int *decoded_options_count,
 		    struct cl_decoded_option **decoded_options)
 {
-    unsigned int i;								
+    unsigned int i;
 
+#ifdef __EMX__
     /* Preload compiler if specified by GCCLOAD for faster subsequent runs */
     _emxload_env ("GCCLOAD");
     /* Compilers don't fork (thanks God!) so we can use >32MB RAM */ 
     /* bird: this doesn't matter really as the compiler now should use high */
     /*       memory. But we'll leave it here in case a DLL gets broken. */
     _uflags (_UF_SBRK_MODEL, _UF_SBRK_ARBITRARY);
+#endif
 
   for (i = 1; i < *decoded_options_count; i++)
     {
diff --git a/gcc/config/i386/emx.c b/gcc/config/i386/emx.c
index 06b15a25fc..a7d1e8c816 100644
--- a/gcc/config/i386/emx.c
+++ b/gcc/config/i386/emx.c
@@ -642,8 +642,8 @@ i386_emx_asm_output_aligned_decl_common (FILE *stream, tree decl,
       fprintf ((stream), "\t.comm\t");
       assemble_name ((stream), (name));
       fprintf ((stream), ", %lld\t# %lld\n",
-	       (((size) + xalign - 1) / xalign) * xalign,
-               (size));
+			   (long long)(((size) + xalign - 1) / xalign) * xalign,
+			   (long long)(size));
   }
 }
 
diff --git a/gcc/config/i386/emx.h b/gcc/config/i386/emx.h
index 1fffc3a586..2803407350 100644
--- a/gcc/config/i386/emx.h
+++ b/gcc/config/i386/emx.h
@@ -51,8 +51,14 @@ Boston, MA 02111-1307, USA.  */
 #include <stdio.h>              /* for FILE* */
 
 /* Some additional system-dependent includes... */
+#ifdef __EMX__
 #include <sys/emxload.h>
 #include <sys/uflags.h>
+
+#define HOST_EXE_EXT ".exe"
+#else
+#define HOST_EXE_EXT ""
+#endif
 
 /* Generate stack probes for allocations bigger than 4000. */
 #define CHECK_STACK_LIMIT               4000
@@ -498,7 +504,7 @@ do {                                                                    \
 #define ENDFILE_SPEC "%{Zomf:-lend}"
 
 /* Override the default linker program (collect2).  */
-#define LINKER_NAME                     "%{Zomf:emxomf}ld.exe"
+#define LINKER_NAME                     "%{Zomf:emxomf}ld" HOST_EXE_EXT
 
 
 
@@ -571,7 +577,7 @@ do {                                                                    \
 #define ENDFILE_SPEC "%{!Zaout:-lend}"
 
 /* Override the default linker program (collect2).  */
-#define LINKER_NAME "%{!Zaout:emxomf}ld.exe"
+#define LINKER_NAME "%{!Zaout:emxomf}ld" HOST_EXE_EXT
 
 #endif
 
diff --git a/gcc/config/i386/i386-options.cc b/gcc/config/i386/i386-options.cc
index ad67374422..363363968a 100644
--- a/gcc/config/i386/i386-options.cc
+++ b/gcc/config/i386/i386-options.cc
@@ -1893,7 +1893,7 @@ ix86_default_align (struct gcc_options *opts)
 }
 
 #ifndef USE_IX86_FRAME_POINTER
-#ifdef __OS2__
+#if defined(__OS2__) || defined(EMX)
 /* OS/2 needs the frame pointer to have proper stack trace when debugging
    so it needs to be enabled by default. However, the configure portion that
    sets a default for --enable-frame-pointer is executed after config.gcc which
@@ -1933,7 +1933,7 @@ ix86_recompute_optlev_based_flags (struct gcc_options *opts,
 	  SET_OPTION_IF_UNSET (opts, opts_set, flag_omit_frame_pointer,
 			       !(USE_IX86_FRAME_POINTER || opts->x_optimize_size));
       if (opts->x_flag_asynchronous_unwind_tables == 2)
-#ifdef __OS2__
+#if defined(__OS2__) || defined(EMX)
 	/* Don't emit DWARF2 unwind tables on OS/2 by default as it makes no use
 	   of it (this would only add unresolved __ehInit in each object).  */
 	opts->x_flag_asynchronous_unwind_tables = 0;
diff --git a/gcc/config/i386/i386.cc b/gcc/config/i386/i386.cc
index 8bac826859..5173793e0b 100644
--- a/gcc/config/i386/i386.cc
+++ b/gcc/config/i386/i386.cc
@@ -35,7 +35,7 @@ along with GCC; see the file COPYING3.  If not see
 #include "stringpool.h"
 #include "expmed.h"
 #include "optabs.h"
-#ifdef __EMX__
+#if defined(__EMX__) || defined(EMX)
 #include "cp/cp-tree.h" /* we need SET_DECL_LANGUAGE */
 #include "dbxout.h"
 #endif
@@ -116,7 +116,7 @@ static void ix86_emit_restore_reg_using_pop (rtx, bool = false);
 #define CHECK_STACK_LIMIT (-1)
 #endif
 
-#ifdef EMX
+#if defined(__EMX__) || defined(EMX)
 extern bool i386_emx_binds_local_p (const_tree);
 #endif
 
@@ -11383,7 +11383,7 @@ ix86_legitimate_constant_p (machine_mode mode, rtx x)
       if (SYMBOL_REF_TLS_MODEL (x))
 	return false;
 
-#ifndef __EMX__ /* 2009-01-15 */
+#if !(defined(__EMX__) || defined(EMX)) /* 2009-01-15 */
       /* DLLIMPORT symbols are never valid.  */
       if (TARGET_DLLIMPORT_DECL_ATTRIBUTES
 	  && SYMBOL_REF_DLLIMPORT_P (x))
@@ -12752,7 +12752,7 @@ ix86_legitimize_address (rtx x, rtx, machine_mode mode)
       return gen_rtx_PLUS (Pmode, t, XEXP (XEXP (x, 0), 1));
     }
 
-#ifndef __EMX__ /* 2009-01-15 */
+#if !(defined(__EMX__) || defined(EMX)) /* 2009-01-15 */
   if (TARGET_DLLIMPORT_DECL_ATTRIBUTES)
     {
 #if TARGET_PECOFF
@@ -27095,7 +27095,7 @@ static const scoped_attribute_specs *const ix86_attribute_table[] =
 #define TARGET_BINDS_LOCAL_P ix86_binds_local_p
 #endif
 #if TARGET_DLLIMPORT_DECL_ATTRIBUTES
-#ifndef __EMX__
+#if !(defined(__EMX__) || defined(EMX))
 #undef TARGET_BINDS_LOCAL_P
 #define TARGET_BINDS_LOCAL_P i386_pe_binds_local_p
 #else
diff --git a/gcc/config/i386/i386.h b/gcc/config/i386/i386.h
index 71d519896b..14a7e7d581 100644
--- a/gcc/config/i386/i386.h
+++ b/gcc/config/i386/i386.h
@@ -1684,7 +1684,7 @@ typedef struct ix86_args {
  				   MS_ABI for ms abi.  */
   tree decl;			/* Callee decl.  */
 
-#ifdef __OS2__
+#if defined(__OS2__) || defined(EMX)
   int fpu_regno;		/* next available FPU register number */
   int fpu_nregs;		/* # registers available for passing */
   int ec_slots;			/* # eyecatcher slots left (see optlink specs) */
diff --git a/gcc/config/i386/predicates.md b/gcc/config/i386/predicates.md
index ffe644be53..a04fc31b12 100644
--- a/gcc/config/i386/predicates.md
+++ b/gcc/config/i386/predicates.md
@@ -674,7 +674,7 @@
       || (TARGET_INDIRECT_BRANCH_REGISTER
           && ix86_nopic_noplt_attribute_p (op)))
     return false;
-#ifndef __EMX__ /* mangles dllimport symbols in a bad way on OS/2 */
+#if !(defined(__EMX__) || defined(EMX)) /* mangles dllimport symbols in a bad way on OS/2 */
   if (TARGET_DLLIMPORT_DECL_ATTRIBUTES && SYMBOL_REF_DLLIMPORT_P (op))
     return false;
 #endif
diff --git a/gcc/config/i386/t-emx b/gcc/config/i386/t-emx
index 5764a31190..8291ad5fbc 100644
--- a/gcc/config/i386/t-emx
+++ b/gcc/config/i386/t-emx
@@ -58,7 +58,7 @@ STMP_FIXPROTO   =
 TARGET_LIBGCC2_CFLAGS = -Zaout -O2 -fomit-frame-pointer -Wall -DNDEBUG
 
 # Allocate enough stack and use high memory
-T_CFLAGS = -Zstack 8192 -Zhigh-mem
+#T_CFLAGS = -Zstack 8192 -Zhigh-mem
 
 # Provide alternative source code for libgcc1
 LIBGCC1         = libgcc1-asm.a
diff --git a/gcc/cp/dump.cc b/gcc/cp/dump.cc
index b1170d96fa..b182c1fd67 100644
--- a/gcc/cp/dump.cc
+++ b/gcc/cp/dump.cc
@@ -23,7 +23,7 @@ along with GCC; see the file COPYING3.  If not see
 #include "coretypes.h"
 #include "cp-tree.h"
 #include "tree-dump.h"
-#ifdef __OS2__
+#if defined(__OS2__) || defined(EMX)
 #include "stringpool.h"
 #include "attribs.h"
 #endif
@@ -51,7 +51,7 @@ dump_stmt (dump_info_p di, const_tree t)
     dump_int (di, "line", EXPR_LINENO (t));
 }
 
-#ifdef __OS2__ /* bird hacking */
+#if defined(__OS2__) || defined(EMX) /* bird hacking */
 static void cp_dump_attributes (dump_info_p di, tree t)
 {
   tree attr = NULL;
@@ -91,9 +91,9 @@ cp_dump_tree (void* dump_info, tree t)
 	dump_string_field (di, "lang", language_to_string (DECL_LANGUAGE (t)));
     }
 
-#if 1 /* bird hacking */
+#if defined(__OS2__) || defined(EMX) /* bird hacking */
   cp_dump_attributes (di, t);
-#endif 
+#endif
 
   switch (code)
     {
diff --git a/gcc/gcc.cc b/gcc/gcc.cc
index 3f749c9f80..1cddd70aeb 100644
--- a/gcc/gcc.cc
+++ b/gcc/gcc.cc
@@ -5355,7 +5355,7 @@ process_command (unsigned int decoded_options_count,
       const char *obase;
       char *tofree = NULL;
       if (!output_file || not_actual_file_p (output_file))
-#ifndef __OS2__
+#if !(defined(__OS2__) || defined(EMX))
 	obase = "a";
 #else
 	{
@@ -6261,7 +6261,7 @@ do_spec_1 (const char *spec, int inswitch, const char *soft_matched_part)
 
 	  case 'b':
 	    /* Don't use %b in the linker command.  */
-#ifndef __OS2__ /* this causes 'internal compiler error: in do_spec_1, at gcc.c:6063' with GCC 11.x - dunno why - FIXME */ 
+#if !(defined(__OS2__) || defined(EMX)) /* this causes 'internal compiler error: in do_spec_1, at gcc.c:6063' with GCC 11.x - dunno why - FIXME */
 	    gcc_assert (suffixed_basename_length);
 #endif
 	    if (!this_is_output_file && dumpdir_length)
@@ -9463,7 +9463,7 @@ lookup_compiler (const char *name, size_t length, const char *language)
 	break;
     }
 
-#if defined (OS2) ||defined (HAVE_DOS_BASED_FILE_SYSTEM)
+#ifdef HAVE_DOS_BASED_FILE_SYSTEM
   /* Look again, but case-insensitively this time.  */
   if (cp < compilers)
     for (cp = compilers + n_compilers - 1; cp >= compilers; cp--)
diff --git a/gcc/genattrtab.cc b/gcc/genattrtab.cc
index c14069b062..4bfa9bb54b 100644
--- a/gcc/genattrtab.cc
+++ b/gcc/genattrtab.cc
@@ -5243,7 +5243,7 @@ main (int argc, const char **argv)
   class insn_def *id;
   int i;
 
-#ifdef EMX
+#ifdef __EMX__
   /* Otherwise we can't use more than 32Mb memory and genattrtab uses a lot */
   _uflags (_UF_SBRK_MODEL, _UF_SBRK_ARBITRARY);
 #endif
diff --git a/gcc/gengtype.cc b/gcc/gengtype.cc
index 7cc1b1cf41..0207c2567c 100644
--- a/gcc/gengtype.cc
+++ b/gcc/gengtype.cc
@@ -296,7 +296,7 @@ read_input_line (FILE *list, char **herep, char **linep, struct fileloc *pos)
       /* No space for a lang_bitmap is necessary.  Discard the '['. */
       c = getc (list);
       line = here;
-#ifndef __EMX__
+#if !(defined(__EMX__) || defined(EMX))
       while (c != ']' && c != '\n' && c != EOF)
 #else
       while (c != ']' && c != '\n' && c != EOF && c != '\r')
@@ -310,7 +310,7 @@ read_input_line (FILE *list, char **herep, char **linep, struct fileloc *pos)
       if (c == ']')
 	{
 	  c = getc (list);	/* eat what should be a newline */
-#ifndef __EMX__
+#if !(defined(__EMX__) || defined(EMX))
 	  if (c != '\n' && c != EOF)
 #else
 	  if (c != '\n' && c != EOF && c != '\r' )
diff --git a/gcc/reg-stack.cc b/gcc/reg-stack.cc
index 275122e088..1d027e7280 100644
--- a/gcc/reg-stack.cc
+++ b/gcc/reg-stack.cc
@@ -2807,7 +2807,7 @@ convert_regs_entry (void)
   /* GCC-OS2: fp regs passing
      Figure out the arguments passed in stack registers.  */
   tree parm = DECL_ARGUMENTS (current_function_decl);
-  int incoming_arg [REG_STACK_SIZE];
+  rtx incoming_arg [REG_STACK_SIZE];
   int i;
 
   memset (incoming_arg, 0, sizeof (incoming_arg));
@@ -2816,7 +2816,7 @@ convert_regs_entry (void)
       rtx x = DECL_INCOMING_RTL (parm);
 /* check me  */
       if (STACK_REG_P (x))
-	incoming_arg[REGNO (x) - FIRST_STACK_REG] = (int) x;
+	incoming_arg[REGNO (x) - FIRST_STACK_REG] = x;
 
       parm = TREE_CHAIN (parm);
     }
diff --git a/gcc/reload1.cc b/gcc/reload1.cc
index 329324340b..2a8941d8db 100644
--- a/gcc/reload1.cc
+++ b/gcc/reload1.cc
@@ -2943,7 +2943,7 @@ eliminate_regs (rtx x, machine_mode mem_mode, rtx insn)
 {
   if (reg_eliminate == NULL)
     {
-#ifndef __OS2__ // FIXME
+#if !(defined(__OS2__) || defined(EMX)) // FIXME
       gcc_assert (targetm.no_register_allocation);
 #endif
       return x;
diff --git a/gcc/target-def.h b/gcc/target-def.h
index f37833d008..b42e2b5934 100644
--- a/gcc/target-def.h
+++ b/gcc/target-def.h
@@ -62,7 +62,7 @@
 # else
 #  ifdef TARGET_ASM_NAMED_SECTION
 #   define TARGET_ASM_CONSTRUCTOR default_named_section_asm_out_constructor
-#  elif __OS2__
+#  elif defined(__OS2__) || defined(EMX)
 #   define TARGET_ASM_CONSTRUCTOR default_stabs_asm_out_constructor
 #  else
 #   define TARGET_ASM_CONSTRUCTOR default_asm_out_constructor
@@ -76,7 +76,7 @@
 # else
 #  ifdef TARGET_ASM_NAMED_SECTION
 #   define TARGET_ASM_DESTRUCTOR default_named_section_asm_out_destructor
-#  elif __OS2__
+#  elif defined(__OS2__) || defined(EMX)
 #   define TARGET_ASM_DESTRUCTOR default_stabs_asm_out_destructor
 #  else
 #   define TARGET_ASM_DESTRUCTOR default_asm_out_destructor
diff --git a/libstdc++-v3/crossconfig.m4 b/libstdc++-v3/crossconfig.m4
index b3269cb88e..ac16c7a24d 100644
--- a/libstdc++-v3/crossconfig.m4
+++ b/libstdc++-v3/crossconfig.m4
@@ -219,6 +219,12 @@ case "${host}" in
     AC_CHECK_FUNCS(timespec_get)
     AC_CHECK_FUNCS(sockatmark)
     ;;
+  *-os2*)
+    GLIBCXX_CHECK_LINKER_FEATURES
+    GLIBCXX_CHECK_MATH_SUPPORT
+    GLIBCXX_CHECK_STDLIB_SUPPORT
+    AC_CHECK_FUNCS(aligned_alloc posix_memalign memalign _aligned_malloc)
+    ;;
   *-qnx6.1* | *-qnx6.2*)
     SECTION_FLAGS='-ffunction-sections -fdata-sections'
     AC_SUBST(SECTION_FLAGS) 
