From f67155fb02c918279eb70ea53d34d66d5e86c31e Mon Sep 17 00:00:00 2001
From: KO Myung-Hun <komh78@gmail.com>
Date: Tue, 24 Mar 2026 22:45:30 +0900
Subject: [PATCH 7/7] Fix SIGSEGV when passing -Wl,--version

This causes the linker detection of meson to fail
---
 gcc/gcc.cc | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/gcc/gcc.cc b/gcc/gcc.cc
index 1cddd70aeb..2ec357a93c 100644
--- a/gcc/gcc.cc
+++ b/gcc/gcc.cc
@@ -5359,6 +5359,7 @@ process_command (unsigned int decoded_options_count,
 	obase = "a";
 #else
 	{
+	  obase = "a";
 	  for (int i = 0; i < n_infiles; i++)
 	    {
 	      if (infiles[i].language
@@ -5370,7 +5371,7 @@ process_command (unsigned int decoded_options_count,
 	      tofree = xstrdup (lbasename (infiles[i].name));
 	      obase = tofree;
 
-	      if ((temp1 = strrchr (obase + 1, '.')))
+	      if ((temp1 = strrchr (tofree + 1, '.')))
 		*temp1 = '\0';
 	      break;
 	    }
-- 
2.43.0

