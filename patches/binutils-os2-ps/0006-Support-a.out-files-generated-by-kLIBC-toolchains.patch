From 3c5d0c6af11f85f0bffd1b7ae6f5c88270a507c9 Mon Sep 17 00:00:00 2001
From: KO Myung-Hun <komh78@gmail.com>
Date: Tue, 2 Jun 2026 15:55:17 +0900
Subject: [PATCH 6/7] Support a.out files generated by kLIBC toolchains

---
 bfd/i386aoutemx.c | 113 ++++++++++++++++++++++++++--------------------
 1 file changed, 63 insertions(+), 50 deletions(-)

diff --git a/bfd/i386aoutemx.c b/bfd/i386aoutemx.c
index 4b67b9ef..b425e99f 100644
--- a/bfd/i386aoutemx.c
+++ b/bfd/i386aoutemx.c
@@ -160,53 +160,88 @@ static const struct aout_backend_data MY(backend_data) = {
 
 #include "aout-target.h"
 
-#ifndef __EMX__
-
-/* Cross-compilation support, borrowed from EMX C runtime library */
-int _fseek_hdr (FILE *);
-
-int _fseek_hdr (FILE *stream)
+static int seek_hdr (bfd *abfd)
 {
   struct
     {
       char magic[2];
       char fill1[6];
-      unsigned short hdr_size;
+      uint16_t hdr_size;
     } exe_hdr;
   struct
     {
       char sig[16];
       char bound;
       char fill1;
-      unsigned short hdr_loc_lo;      /* cannot use long, alignment! */
-      unsigned short hdr_loc_hi;
+      uint16_t hdr_loc_lo;      /* cannot use long, alignment! */
+      uint16_t hdr_loc_hi;
     } patch;
-  long original_pos;
+  file_ptr original_pos;
   int saved_errno;
 
-  original_pos = ftell (stream);
-  if (fread (&exe_hdr, sizeof (exe_hdr), 1, stream) != 1)
+  original_pos = bfd_tell (abfd);
+  if (bfd_read (&exe_hdr, sizeof (exe_hdr), abfd) != sizeof (exe_hdr))
     goto failure;
   if (memcmp (exe_hdr.magic, "MZ", 2) != 0)
-    return (fseek (stream, original_pos, SEEK_SET) == -1 ? -1 : 0);
-  if (fseek (stream, original_pos + 16 * exe_hdr.hdr_size, SEEK_SET) == -1)
-    goto failure;
-  if (fread (&patch, sizeof (patch), 1, stream) != 1)
+    return (bfd_seek (abfd, original_pos, SEEK_SET) == -1 ? -1 : 0);
+  if (bfd_seek (abfd, original_pos + 16 * exe_hdr.hdr_size, SEEK_SET) == -1)
     goto failure;
-  if (memcmp (patch.sig, "emx", 3) != 0)
+  if (bfd_read (&patch, sizeof (patch), abfd) != sizeof (patch))
     goto failure;
-  if (fseek (stream, original_pos + patch.hdr_loc_lo
-             + 65536L * patch.hdr_loc_hi, SEEK_SET) == -1)
+  if (memcmp (patch.sig, "emx", 3) == 0)
+    {
+      if (bfd_seek (abfd, original_pos + patch.hdr_loc_lo
+                     + 65536L * patch.hdr_loc_hi, SEEK_SET) == -1)
+        goto failure;
+    }
+  else if (memcmp (patch.sig, "OS/2", 4) == 0)
+    {
+      struct
+        {
+          int16_t  fill1[12];
+          uint16_t lfarlc;
+          int16_t  fill2[17];
+          int32_t  lfanew;
+        } mz_hdr;
+      struct
+        {
+          char magic[2];
+          char fill1[2];
+          int32_t fill2[31];
+          uint32_t data_page;
+        } lx_hdr;
+
+      /* rewind */
+      if (bfd_seek (abfd, original_pos, SEEK_SET) == -1)
+        goto failure;
+      if (bfd_read (&mz_hdr, sizeof (mz_hdr), abfd) != sizeof (mz_hdr))
+        goto failure;
+      /* check if a LX header exists */
+      if (mz_hdr.lfarlc != 0x40)
+        goto failure;
+      /* seek to the LX header */
+      if (bfd_seek (abfd, mz_hdr.lfanew, SEEK_SET) == -1)
+        goto failure;
+      if (bfd_read (&lx_hdr, sizeof (lx_hdr), abfd) != sizeof (lx_hdr))
+        goto failure;
+      /* check if real LX header */
+      if (memcmp (&lx_hdr.magic, "LX", 2) != 0)
+        goto failure;
+      /* seek to the aout header with ZMAGIC */
+      if (bfd_seek (abfd, lx_hdr.data_page - 1024, SEEK_SET) == -1)
+        goto failure;
+      return 0;
+    }
+  else
     goto failure;
   return 0;
 
 failure:
   saved_errno = errno;
-  fseek (stream, original_pos, SEEK_SET);
+  bfd_seek (abfd, original_pos, SEEK_SET);
   errno = saved_errno;
   return -1;
 }
-#endif
 
 
 /*
@@ -216,38 +251,15 @@ const bfd_target *
 MY(object_p) (abfd)
   bfd *abfd;
 {
-#if 0
-  struct external_exec exec_bytes;	/* Raw exec header from file */
-  struct internal_exec exec;		/* Cleaned-up exec header */
-  const bfd_target *target;
-  size_t org_pos, add;
-
-  org_pos = bfd_tell (abfd);
-  (void)_fseek_hdr(bfd_cache_lookup(abfd));
-  add = bfd_tell (abfd) - org_pos;
-
-  if (bfd_read ((void *) &exec_bytes, EXEC_BYTES_SIZE, abfd)
-      != EXEC_BYTES_SIZE)
-  {
-    if (bfd_get_error () != bfd_error_system_call)
-      bfd_set_error (bfd_error_wrong_format);
-    return 0;
-  }
-
-  exec.a_info = bfd_h_get_32 (abfd, exec_bytes.e_info);
-
-  if (N_BADMAG (exec))
-    return 0;
-
-  NAME(aout,swap_exec_header_in)(abfd, &exec_bytes, &exec);
-  exec.a_hdrofs = add;
-  target = NAME(aout,some_aout_object_p) (abfd, &exec, MY(callback));
-  return target;
-#else
   struct external_exec exec_bytes;	/* Raw exec header from file.  */
   struct internal_exec exec;	/* Cleaned-up exec header.  */
   const bfd_target *target;
   bfd_size_type amt = EXEC_BYTES_SIZE;
+  file_ptr org_pos, hdrofs;
+
+  org_pos = bfd_tell (abfd);
+  seek_hdr (abfd);
+  hdrofs = bfd_tell (abfd) - org_pos;
 
   if (bfd_read ((void *) &exec_bytes, amt, abfd) != amt)
     {
@@ -276,6 +288,8 @@ MY(object_p) (abfd)
   exec.a_info = SWAP_MAGIC (exec_bytes.e_info);
 #endif /* SWAP_MAGIC */
 
+  exec.a_hdrofs = hdrofs;
+
   target = (bfd_target*) NAME(aout,some_aout_object_p) (abfd, &exec, MY(callback));
 
 #ifdef ENTRY_CAN_BE_ZERO
@@ -298,7 +312,6 @@ MY(object_p) (abfd)
 #endif /* ENTRY_CAN_BE_ZERO */
 
   return target;
-#endif
 }
 
 reloc_howto_type *
-- 
2.43.0

