From bbb904b56b420ddcd184d47070283912d8ba9734 Mon Sep 17 00:00:00 2001
From: KO Myung-Hun <komh78@gmail.com>
Date: Fri, 20 Feb 2026 15:16:00 +0900
Subject: [PATCH 1/3] Add build scripts for i686-pc-os2-emx target

---
 conf-cross-os2emx | 21 +++++++++++++++++++++
 1 file changed, 21 insertions(+)
 create mode 100755 conf-cross-os2emx

diff --git a/conf-cross-os2emx b/conf-cross-os2emx
new file mode 100755
index 000000000..dcdfc6515
--- /dev/null
+++ b/conf-cross-os2emx
@@ -0,0 +1,21 @@
+#! /bin/sh
+
+PREFIXROOT=${PREFIXROOT:-$HOME}
+
+prefix=${PREFIXROOT%/}/opt/os2emx
+target=i686-pc-os2-emx
+
+export CFLAGS="-DEMX -O2"
+export CXXFLAGS="-DEMX -O2"
+
+opts="
+    --prefix=$prefix
+    --target=$target
+    --disable-nls
+    --disable-gold
+    --disable-ld
+    --disable-lto
+    --disable-plugins
+"
+
+$(dirname "$0")/configure $opts "$@"
-- 
2.43.0

