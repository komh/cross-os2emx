From 33fd2708ddae9042dd93080c3d5d83b76772dab6 Mon Sep 17 00:00:00 2001
From: KO Myung-Hun <komh78@gmail.com>
Date: Sun, 1 Mar 2026 18:34:46 +0900
Subject: [PATCH 5/5] Build libssp

---
 conf-cross-os2emx | 1 -
 mk-cross-os2emx   | 2 ++
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/conf-cross-os2emx b/conf-cross-os2emx
index 37c1053a1..dd565bf88 100755
--- a/conf-cross-os2emx
+++ b/conf-cross-os2emx
@@ -22,7 +22,6 @@ opts="
     --enable-checking=release
     --disable-bootstrap
     --disable-nls
-    --disable-ssp
     --disable-libquadmath
     --disable-multilib
     --disable-lto
diff --git a/mk-cross-os2emx b/mk-cross-os2emx
index 3013ea91e..9bdea141d 100755
--- a/mk-cross-os2emx
+++ b/mk-cross-os2emx
@@ -3,6 +3,8 @@
 make all-gcc &&
 make all-target-libgcc &&
 make all-target-libstdc++-v3 &&
+make all-target-libssp &&
 make install-gcc &&
 make install-target-libgcc &&
 make install-target-libstdc++-v3 &&
+make install-target-libssp
