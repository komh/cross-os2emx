From 354c8afc7cb242a65fefbbfd78f5661a2a35ee35 Mon Sep 17 00:00:00 2001
From: KO Myung-Hun <komh78@gmail.com>
Date: Fri, 20 Feb 2026 16:03:00 +0900
Subject: [PATCH 1/7] Add build scripts for i686-pc-os2-emx target

---
 conf-cross-os2emx | 33 +++++++++++++++++++++++++++++++++
 mk-cross-os2emx   | 11 +++++++++++
 2 files changed, 44 insertions(+)
 create mode 100755 conf-cross-os2emx
 create mode 100755 mk-cross-os2emx

diff --git a/conf-cross-os2emx b/conf-cross-os2emx
new file mode 100755
index 0000000000..725ade7e0d
--- /dev/null
+++ b/conf-cross-os2emx
@@ -0,0 +1,33 @@
+#! /bin/sh
+
+PREFIXROOT=${PREFIXROOT:=$HOME}
+
+prefix=${PREFIXROOT%/}/opt/os2emx
+target=i686-pc-os2-emx
+
+export CFLAGS="-DEMX -O2 -D_FORTIFY_SOURCE=0"
+export CXXFLAGS="-DEMX -O2 -D_FORTIFY_SOURCE=0"
+
+opts="
+    --prefix=$prefix
+    --target=$target
+    --with-sysroot=$prefix/$target
+    --with-gcc-major-version-only
+    --with-gnu-as
+    --with-as=$prefix/bin/$target-as
+    --with-ld=$prefix/bin/$target-ld
+    --enable-languages=c,c++
+    --enable-threads
+    --enable-checking=release
+    --disable-bootstrap
+    --disable-nls
+    --disable-ssp
+    --disable-libquadmath
+    --disable-libgomp
+    --disable-multilib
+    --disable-lto
+    --disable-shared
+    --disable-symvers
+"
+
+$(dirname $0)/configure $opts "$@"
diff --git a/mk-cross-os2emx b/mk-cross-os2emx
new file mode 100755
index 0000000000..843266240c
--- /dev/null
+++ b/mk-cross-os2emx
@@ -0,0 +1,11 @@
+#!/bin/sh
+
+make all-gcc \
+     all-target-libgcc \
+     all-target-libstdc++-v3 \
+     "$@" || exit 1
+
+make install-gcc \
+     install-target-libgcc \
+     install-target-libstdc++-v3 \
+     "$@"
-- 
2.43.0

