From f18ad53b138a879ba73c23882af6250cc896ffc6 Mon Sep 17 00:00:00 2001
From: KO Myung-Hun <komh78@gmail.com>
Date: Fri, 20 Feb 2026 16:03:00 +0900
Subject: [PATCH 1/5] Add build scripts for i686-pc-os2-emx target

---
 conf-cross-os2emx | 32 ++++++++++++++++++++++++++++++++
 mk-cross-os2emx   |  8 ++++++++
 2 files changed, 40 insertions(+)
 create mode 100755 conf-cross-os2emx
 create mode 100755 mk-cross-os2emx

diff --git a/conf-cross-os2emx b/conf-cross-os2emx
new file mode 100755
index 000000000..0cb6810c2
--- /dev/null
+++ b/conf-cross-os2emx
@@ -0,0 +1,32 @@
+#! /bin/sh
+
+PREFIXROOT=${PREFIXROOT:=$HOME}
+
+prefix=${PREFIXROOT%/}/opt/os2emx
+target=i686-pc-os2-emx
+
+export CFLAGS="-DEMX -O2 -D_FORTIFY_SOURCE=0"
+export CXXFLAGS="-DEMX -O2 -D_FORTIFY_SOURCE=0"
+
+opts="
+    --prefix=$prefix
+    --target=$target
+    --with-sysroot=$prefix/$target
+    --with-gcc-major-version-only
+    --with-gnu-as
+    --with-as=$prefix/bin/$target-as
+    --with-ld=$prefix/bin/$target-ld
+    --enable-languages=c,c++
+    --enable-threads
+    --enable-checking=release
+    --disable-bootstrap
+    --disable-nls
+    --disable-ssp
+    --disable-libquadmath
+    --disable-multilib
+    --disable-lto
+    --disable-shared
+    --disable-symvers
+"
+
+$(dirname $0)/configure $opts "$@"
diff --git a/mk-cross-os2emx b/mk-cross-os2emx
new file mode 100755
index 000000000..3013ea91e
--- /dev/null
+++ b/mk-cross-os2emx
@@ -0,0 +1,8 @@
+#!/bin/sh
+
+make all-gcc &&
+make all-target-libgcc &&
+make all-target-libstdc++-v3 &&
+make install-gcc &&
+make install-target-libgcc &&
+make install-target-libstdc++-v3 &&
-- 
