# the name of the target operating system
set(CMAKE_SYSTEM_NAME OS2)

# the tager architecture
set(CMAKE_SYSTEM_PROCESSOR @TARGETCPU@)

# which compilers to use for C and C++
set(CMAKE_C_COMPILER @PREFIX@/bin/@TARGETSPEC@-gcc)
set(CMAKE_CXX_COMPILER @PREFIX@/bin/@TARGETSPEC@-g++)

# the path to be passed to the compiler and the linker in the --sysroot flag
set(CMAKE_SYSROOT @PREFIX@/@TARGET@)

# where is the target environment located
set(CMAKE_FIND_ROOT_PATH ${CMAKE_SYSROOT})

# where is the target environment located
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)

# search headers and libraries in the target environment
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
